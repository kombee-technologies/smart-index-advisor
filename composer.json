{
  "name": "kombee-technologies/smart-index-advisor",
  "description": "Production automated Smart Index Advisor for Laravel.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Kombee Technologies"
    }
  ],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
  },
  "suggest": {
    "illuminate/mail": "Required to email reports from index-advisor:report"
  },
  "autoload": {
    "psr-4": {
      "Kombee\\IndexAdvisor\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Kombee\\IndexAdvisor\\IndexAdvisorServiceProvider"
      ]
    }
  }
}
